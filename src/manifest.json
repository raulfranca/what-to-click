{
  "manifest_version": 3,
  "name": "What-to-click",
  "version": "1.12.6",
  "description": "Fully offline, AI-powered how-to documentation creator.",
  "icons": {
    "48": "icons/record.svg"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_icon": "icons/record.svg",
    "default_title": "Record what to click"
  },
  "background": {
    "service_worker": "background/index.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/index.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/page.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+R"
      }
    }
  }
}